# Variables de entorno requeridas para portusalud
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el archivo .env

# Base de datos (en producción Render la inyecta automáticamente)
DATABASE_URL=postgres://usuario:password@localhost/portusalud_development

# Redis — usado por Sidekiq y caché de resultados de búsqueda
REDIS_URL=redis://localhost:6379/0

# Rails credentials (en producción usar RAILS_MASTER_KEY en lugar de este archivo)
# SECRET_KEY_BASE=

# Entorno
RAILS_ENV=development

# Puma workers en producción (recomendado: 2 para Render Starter)
# WEB_CONCURRENCY=2
