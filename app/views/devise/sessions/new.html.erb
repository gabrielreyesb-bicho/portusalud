<%# Inicio de sesión — /cuenta/sesion %>

<div class="min-h-[70vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">

    <div class="text-center mb-8">
      <%= link_to root_path do %>
        <%= image_tag "icono_escudo.png", alt: "portusalud", class: "h-16 w-auto mx-auto mb-4" %>
      <% end %>
      <h1 class="text-2xl font-semibold text-pts-800">Iniciar sesión</h1>
      <p class="text-sm text-pts-600 mt-2">Accede a tu lista de medicamentos</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                 html: { class: "space-y-4" }) do |f| %>

      <div>
        <%= f.label :email, "Correo electrónico",
            class: "block text-sm font-medium text-pts-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-3 text-base border border-pts-300 rounded-xl
                    focus:outline-none focus:ring-2 focus:ring-pts-400 focus:border-pts-400
                    text-pts-900 placeholder-pts-300",
            placeholder: "tu@correo.com" %>
      </div>

      <div>
        <%= f.label :password, "Contraseña",
            class: "block text-sm font-medium text-pts-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-3 text-base border border-pts-300 rounded-xl
                    focus:outline-none focus:ring-2 focus:ring-pts-400 focus:border-pts-400
                    text-pts-900" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me,
              class: "w-4 h-4 text-pts-500 border-pts-300 rounded focus:ring-pts-400" %>
          <%= f.label :remember_me, "Recordarme",
              class: "text-sm text-pts-600" %>
        </div>
      <% end %>

      <%= f.submit "Iniciar sesión",
          class: "w-full py-3 bg-pts-500 text-white font-medium rounded-xl
                  hover:bg-pts-600 active:bg-pts-700 transition-colors cursor-pointer text-base" %>

    <% end %>

    <div class="mt-6 text-center space-y-2 text-sm">
      <%= link_to "¿Olvidaste tu contraseña?", new_user_password_path,
          class: "text-pts-600 hover:text-pts-500 block" %>
      <%= link_to "Crear una cuenta", new_user_registration_path,
          class: "text-pts-500 font-medium hover:text-pts-600 block" %>
    </div>

  </div>
</div>
