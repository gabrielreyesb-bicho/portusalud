<%# Inicio de sesión — /cuenta/sesion %>

<div class="min-h-[70vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-xs mx-auto">

    <div class="text-center mb-8">
      <%= link_to root_path, class: "block mb-5" do %>
        <%= image_tag "logo_trimmed.png", alt: "portusalud", class: "h-28 w-auto mx-auto block" %>
      <% end %>
      <h1 class="text-2xl font-semibold text-pts-800">Iniciar sesión</h1>
      <p class="text-sm text-pts-600 mt-2">Accede a tu lista de medicamentos</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                 html: { class: "flex flex-col gap-4" }) do |f| %>

      <div class="flex flex-col gap-1">
        <%= f.label :email, "Correo electrónico",
            class: "text-sm font-medium text-pts-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "px-4 py-3 text-base border border-pts-300 rounded-xl
                    focus:outline-none focus:ring-2 focus:ring-pts-400 focus:border-pts-400
                    text-pts-900 placeholder-pts-300",
            placeholder: "tu@correo.com",
            style: "width: 100%; box-sizing: border-box;" %>
      </div>

      <div class="flex flex-col gap-1">
        <%= f.label :password, "Contraseña",
            class: "text-sm font-medium text-pts-700" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "px-4 py-3 text-base border border-pts-300 rounded-xl
                    focus:outline-none focus:ring-2 focus:ring-pts-400 focus:border-pts-400
                    text-pts-900",
            style: "width: 100%; box-sizing: border-box;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me,
              class: "w-4 h-4 text-pts-500 border-pts-300 rounded focus:ring-pts-400" %>
          <%= f.label :remember_me, "Recordarme",
              class: "text-sm text-pts-600" %>
        </div>
      <% end %>

      <%= f.submit "Iniciar sesión",
          class: "py-3 bg-pts-500 text-white font-medium rounded-xl
                  hover:bg-pts-600 active:bg-pts-700 transition-colors cursor-pointer text-base" %>

    <% end %>

    <%= render "devise/shared/google_button" %>

    <div class="mt-6 text-center flex flex-col gap-2 text-sm">
      <%= link_to "¿Olvidaste tu contraseña?", new_user_password_path,
          class: "text-pts-600 hover:text-pts-500" %>
      <%= link_to "Crear una cuenta", new_user_registration_path,
          class: "text-pts-500 font-medium hover:text-pts-600" %>
    </div>

  </div>
</div>
