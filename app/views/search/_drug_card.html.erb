<%# Tarjeta básica de resultado — se enriquece en Etapa 3 con precios por farmacia %>
<article class="border border-pts-200 rounded-xl p-5 hover:border-pts-400 hover:shadow-sm transition-all bg-white">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <%# Nombre y dosificación %>
      <h2 class="text-lg font-semibold text-pts-800 leading-snug">
        <%= link_to drug.name, comparar_path(drug.slug),
            class: "hover:text-pts-500 transition-colors" %>
        <span class="text-pts-600 font-normal text-base ml-1"><%= drug.dosage %></span>
      </h2>

      <%# Principio activo %>
      <p class="text-sm text-pts-700 mt-0.5">
        <span class="font-medium">Principio activo:</span>
        <%= drug.active_ingredient.capitalize %>
      </p>

      <%# Forma farmacéutica y vía %>
      <p class="text-sm text-pts-600 mt-0.5">
        <%= [drug.form, drug.via].compact.map(&:capitalize).join(" · ") %>
        <% if drug.therapeutic_group.present? %>
          <span class="text-pts-300 mx-1">·</span>
          <span class="text-pts-600"><%= drug.therapeutic_group %></span>
        <% end %>
      </p>
    </div>

    <%# Badges %>
    <div class="flex flex-col gap-1.5 shrink-0 items-end">
      <% if drug.requires_prescription? %>
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                     bg-red-50 text-red-700">
          Requiere receta
        </span>
      <% end %>
    </div>
  </div>

  <%# Resumen de precios si hay entradas %>
  <% if drug.price_entries.any? %>
    <% best = drug.price_entries.min_by(&:price_per_unit) %>
    <div class="mt-4 pt-3 border-t border-pts-100 flex items-center justify-between">
      <span class="text-sm text-pts-600">
        Desde <strong class="text-pts-800 font-semibold">$<%= number_with_precision(best.price_per_unit, precision: 2) %></strong>
        por pieza en <%= best.pharmacy.name %>
      </span>
      <%= link_to "Ver comparativo →", comparar_path(drug.slug),
          class: "text-sm text-pts-500 font-medium hover:text-pts-600 transition-colors" %>
    </div>
  <% end %>
</article>
