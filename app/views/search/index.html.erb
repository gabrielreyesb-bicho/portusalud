<%# Página de resultados de búsqueda %>

<div class="max-w-3xl mx-auto px-4 py-8">

  <%# Buscador en la parte superior %>
  <div class="mb-8">
    <%= render "shared/search_bar", query: @query %>
  </div>

  <%# Resultados %>
  <% if @query.length < 2 %>
    <div class="text-center mb-6">
      <p class="text-sm text-pts-500 font-medium">Escribe el nombre del medicamento que buscas</p>
    </div>

    <% if @sample_drug %>
      <p class="text-xs text-pts-400 text-center mb-3 uppercase tracking-wide">Ejemplo de lo que verás</p>
      <%= render "drug_card", drug: @sample_drug %>
    <% end %>

  <% elsif @drugs.none? %>
    <div class="text-center py-16">
      <p class="text-base text-pts-700 font-medium mb-2">
        No encontramos resultados para "<%= @query %>"
      </p>
      <p class="text-sm text-pts-600">
        Prueba con el nombre genérico o el principio activo del medicamento.
      </p>
    </div>

  <% else %>
    <div class="mb-4 flex items-center justify-between">
      <p class="text-sm text-pts-600">
        <span class="font-medium text-pts-800"><%= @drugs.size %></span>
        <%= @drugs.size == 1 ? "resultado" : "resultados" %>
        para "<span class="font-medium"><%= @query %></span>"
      </p>
    </div>

    <div class="flex flex-col gap-3">
      <%= render partial: "drug_card", collection: @drugs, as: :drug %>
    </div>

  <% end %>

</div>
