<%# Página de inicio — buscador prominente %>

<section class="max-w-2xl mx-auto px-4 pt-16 pb-24 text-center">

  <%# Encabezado %>
  <h1 class="text-3xl font-semibold text-pts-800 mb-3 leading-snug">
    Encuentra el mejor precio<br>en tus medicamentos
  </h1>
  <p class="text-base text-pts-700 mb-10">
    Compara precios entre farmacias y conoce los genéricos equivalentes certificados por COFEPRIS.
    Sin registro. Sin intermediarios.
  </p>

  <%# Buscador %>
  <%= render "shared/search_bar", query: "" %>

  <%# Ejemplo de búsquedas frecuentes %>
  <div class="mt-6 flex flex-wrap justify-center gap-2">
    <span class="text-sm text-pts-600 mr-1">Prueba:</span>
    <% [["Metformina", "metformina"], ["Atorvastatina", "atorvastatina"], ["Glucophage", "glucophage"]].each do |label, q| %>
      <%= link_to label, buscar_path(q: q),
          class: "text-sm px-3 py-1 bg-pts-50 text-pts-700 rounded-full
                  hover:bg-pts-100 transition-colors",
          data: { turbo: false } %>
    <% end %>
  </div>

</section>

<% if @sample_drug %>
  <section class="max-w-2xl mx-auto px-4 pb-16">
    <p class="text-xs text-pts-400 text-center mb-3 uppercase tracking-wide">Ejemplo de lo que verás</p>
    <%= render "search/drug_card", drug: @sample_drug %>
  </section>
<% end %>
